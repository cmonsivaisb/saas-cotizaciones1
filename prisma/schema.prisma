generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(owner)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ownedCompany Company?

  @@map("users")
}

model Company {
  id                 String              @id @default(cuid())
  ownerUserId        String              @unique
  name               String
  contactName        String
  email              String
  phone              String
  city               String
  businessType       String
  status             CompanyStatus       @default(active)
  
  // Payment info for invoices
  bankName           String?
  bankAccount        String?
  clabe              String?
  paymentReference   String?
  
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  owner              User                @relation(fields: [ownerUserId], references: [id])
  customers          Customer[]
  followUps          FollowUp[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
  subscriptionInvoices SubscriptionInvoice[]
  items              Item[]
  notifications     Notification[]
  orderPayments      OrderPayment[]
  orders             Order[]
  quotes             Quote[]
  subscription       Subscription?

  @@map("companies")
}

model Plan {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  priceMxn      Float
  durationDays  Int            @default(30)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  planId             String
  status             SubscriptionStatus @default(pilot)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime
  graceUntil         DateTime?
  suspendedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  subscriptionInvoices SubscriptionInvoice[]
  company            Company            @relation(fields: [companyId], references: [id])
  plan               Plan               @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber Int            @default(autoincrement()) @unique
  companyId    String
  orderId      String?
  concept      String
  amountMxn    Float
  currency     String         @default("MXN")
  status       InvoiceStatus  @default(pending)
  dueAt        DateTime
  paidAt       DateTime?
  quickReference String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  company      Company        @relation(fields: [companyId], references: [id])
  order        Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("invoices")
}

model SubscriptionInvoice {
  id              String                     @id @default(cuid())
  companyId       String
  subscriptionId  String
  concept         String
  amountMxn       Float
  currency        String                     @default("MXN")
  status          InvoiceStatus              @default(pending)
  dueAt           DateTime
  paidAt          DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  company         Company                    @relation(fields: [companyId], references: [id])
  subscription    Subscription               @relation(fields: [subscriptionId], references: [id])
  paymentAttempts SubscriptionPaymentAttempt[]

  @@map("subscription_invoices")
}

model SubscriptionPaymentAttempt {
  id                   String               @id @default(cuid())
  subscriptionInvoiceId String
  provider             String               @default("mercadopago")
  providerPreferenceId String?
  providerPaymentId    String?
  externalReference    String?
  checkoutUrl          String?
  status               PaymentAttemptStatus @default(created)
  rawResponseJson      Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  subscriptionInvoice  SubscriptionInvoice  @relation(fields: [subscriptionInvoiceId], references: [id])

  @@map("subscription_payment_attempts")
}

model MercadoPagoWebhookEvent {
  id             String    @id @default(cuid())
  topic          String
  action         String?
  resourceId     String
  signatureValid Boolean   @default(false)
  payloadJson    Json
  processed      Boolean   @default(false)
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@map("mercadopago_webhook_events")
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  businessName String
  email        String
  phone        String
  businessType String
  message      String?
  status       LeadStatus @default(new)
  source       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("leads")
}

enum ContactMessageStatus {
  new
  read
  replied
  archived
}

model ContactMessage {
  id        String                @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus  @default(new)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@map("contact_messages")
}

model Notification {
  id        String           @id @default(cuid())
  companyId String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id])

  @@map("notifications")
}

model Customer {
  id           String   @id @default(cuid())
  companyId    String
  businessName String
  contactName  String?
  phone        String?
  email        String?
  rfc          String?
  address      String?
  taxId        String?
  source       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id])
  orders       Order[]
  quotes       Quote[]

  @@map("customers")
}

model Item {
  id                 String              @id @default(cuid())
  companyId          String
  sku                String?
  name               String
  description        String?
  unit               String?
  salePrice          Float
  costPrice          Float?
  stockQuantity      Int                 @default(0)
  minimumStock       Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  company            Company             @relation(fields: [companyId], references: [id])
  orderItems         OrderItem[]
  quoteItems         QuoteItem[]

  @@map("items")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  companyId     String
  itemId        String
  movementType  InventoryMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime              @default(now())
  company       Company               @relation(fields: [companyId], references: [id])
  item          Item                  @relation(fields: [itemId], references: [id])

  @@map("inventory_movements")
}

model Quote {
  id            String      @id @default(cuid())
  quoteNumber   Int         @default(autoincrement()) @unique
  companyId    String
  customerId   String
  quoteDate    DateTime    @default(now())
  validUntil   DateTime
  status      QuoteStatus  @default(draft)
  subtotal     Float
  total       Float
  quickReference String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  followUps   FollowUp[]
  orders     Order[]
  items      QuoteItem[]
  company    Company     @relation(fields: [companyId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  itemId      String?
  description String
  qty         Int
  unitPrice   Float
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item?    @relation(fields: [itemId], references: [id])
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model FollowUp {
  id        String          @id @default(cuid())
  companyId String
  quoteId   String
  dueDate   DateTime
  notes     String
  result    FollowUpResult?
  createdAt DateTime        @default(now())
  company   Company         @relation(fields: [companyId], references: [id])
  quote     Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

model Order {
  id              String         @id @default(cuid())
  orderNumber     Int            @default(autoincrement()) @unique
  companyId      String
  customerId     String
  quoteId        String?
  orderDate      DateTime       @default(now())
  dueDate        DateTime?
  status        OrderStatus    @default(pending)
  subtotal       Float
  total         Float
  quickReference String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invoices      Invoice[]
  items         OrderItem[]
  payments      OrderPayment[]
  company       Company        @relation(fields: [companyId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])
  quote         Quote?         @relation(fields: [quoteId], references: [id])

  @@map("orders")
}

model OrderItem {
  id                    String    @id @default(cuid())
  orderId               String
  itemId                String?
  description           String
  qty                   Int
  unitPrice             Float
  amount                Float
  affectsInventory      Boolean   @default(true)
  inventoryDiscountedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  item                  Item?     @relation(fields: [itemId], references: [id])
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderPayment {
  id          String   @id @default(cuid())
  companyId   String
  orderId     String
  paymentDate DateTime @default(now())
  amount      Float
  method      String
  notes       String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_payments")
}

enum UserRole {
  owner
  admin
}

enum CompanyStatus {
  active
  grace_period
  suspended
  cancelled
}

enum SubscriptionStatus {
  pilot
  active
  grace_period
  suspended
  cancelled
}

enum InvoiceStatus {
  pending
  paid
  expired
  cancelled
}

enum PaymentAttemptStatus {
  created
  redirected
  approved
  pending
  rejected
  cancelled
  error
}

enum LeadStatus {
  new
  contacted
  qualified
  closed
  lost
}

enum InventoryMovementType {
  in
  out
  adjustment
}

enum QuoteStatus {
  draft
  sent
  follow_up
  approved
  rejected
  expired
}

enum FollowUpResult {
  no_response
  interested
  waiting
  won
  lost
}

enum OrderStatus {
  pending
  in_progress
  partial_delivered
  delivered
  cancelled
}

enum NotificationType {
  quote_created
  quote_updated
  quote_approved
  quote_rejected
  order_created
  order_updated
  order_status_changed
  order_delivered
  client_created
  client_updated
  invoice_created
  invoice_paid
  inventory_low_stock
  subscription_new
  subscription_renewed
  subscription_suspended
  system
}
